# Telegram Bot — токен из @BotFather
BOT_TOKEN=your_telegram_bot_token

# SendPulse API credentials — Личный кабинет SendPulse → Настройки → API
SP_CLIENT_ID=your_sendpulse_client_id
SP_CLIENT_SECRET=your_sendpulse_client_secret

# SendPulse internal bot ID — узнать через GET https://api.sendpulse.com/telegram/bots
SP_BOT_ID=

# Flow IDs из SendPulse — копировать из URL при редактировании цепочки
SP_FLOW_PASSED_ID=
SP_FLOW_FAILED_ID=

# (Опционально) Google Apps Script Web App URL для аналитики в Google Sheets
# Если не задан — Sheets-логирование пропускается, основной flow работает
SHEETS_WEBHOOK=
